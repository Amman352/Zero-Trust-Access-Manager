# ── Application ───────────────────────────────────────────
APP_NAME=Zero Trust Access Manager
APP_ENV=development
SECRET_KEY=change-me-to-a-64-char-random-string-never-commit-real-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────
POSTGRES_USER=ztam
POSTGRES_PASSWORD=ztam_secret
POSTGRES_DB=ztam_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ztam:ztam_secret@localhost:5432/ztam_db

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Elasticsearch ──────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Email ──────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key
EMAILS_FROM=noreply@yourdomain.com

# ── ML ─────────────────────────────────────────────────────
ML_MODEL_PATH=app/ml/models
ML_RETRAIN_INTERVAL_HOURS=24

# ── CORS ───────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]